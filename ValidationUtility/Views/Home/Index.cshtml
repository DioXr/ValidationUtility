@{
    ViewData["Title"] = "Validation UI";
}

<div class="container-fluid mt-4 px-4">
    <h3 class="mb-4 text-primary">Content Audit Dashboard</h3>

    <div class="row">
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="card shadow-sm border-0 bg-light p-3 mb-3 position-sticky" style="top: 20px;">
                <h6 class="fw-bold mb-3 border-bottom pb-2">Validation Settings</h6>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold mb-1">AI Model</label>
                    <select id="selectedModel" class="form-select form-select-sm">
                        <option value="gemini-2.0-flash">Gemini 1.5 Flash (Fast & Stable)</option>
                        <option value="gemini-2.5-flash" selected>Gemini 2.5 Flash (Newest Standard)</option>
                        <option value="gemini-2.5-pro">Gemini Flash Latest (Auto)</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold mb-1">Reference PDF</label>
                    <input type="file" id="fileInput" class="form-control form-control-sm mb-2" accept=".pdf">
                    <textarea id="referenceText" class="form-control form-control-sm" rows="3" placeholder="PDF text will appear here..."></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold mb-1">Manual JSON</label>
                    <textarea id="manualJsonInput" class="form-control form-control-sm mb-2" rows="3" placeholder='[{"questionTitle": "...", "answer": "A"}]'></textarea>
                    <button id="btnLoadJson" class="btn btn-secondary btn-sm w-100 fw-bold">Load JSON to Screen</button>
                </div>

                <hr>

                <button id="btnFetch" class="btn btn-outline-primary w-100 mb-2 fw-bold">Fetch External App</button>
                <button id="btnRun" class="btn btn-primary w-100 fw-bold shadow-sm">Validate Selected</button>

                <div id="loader" class="d-none text-primary mt-3 small text-center fw-bold">
                    <span class="spinner-border spinner-border-sm me-2"></span> Analyzing...
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">Question Bank</h5>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="selectAll" disabled>
                    <label class="form-check-label text-muted small" for="selectAll">Select All</label>
                </div>
            </div>

            <div id="questionsContainer" style="padding-bottom: 100px;">
                <div class="text-center text-muted p-5 border rounded bg-light">
                    No questions loaded. Click "Fetch External Questions" to begin.
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
<script src="~/js/validator.js"></script>