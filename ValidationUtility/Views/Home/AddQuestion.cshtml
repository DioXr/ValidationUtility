@{
    ViewData["Title"] = "Add Custom Question";
}

<div class="container mt-5" style="max-width: 700px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white fw-bold">
            ➕ Add New Question to Dashboard
        </div>
        <div class="card-body bg-light">
            <div class="mb-3">
                <label class="form-label fw-bold small">Question Text</label>
                <textarea id="newTitle" class="form-control" rows="2" placeholder="e.g., What does HTML stand for?"></textarea>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text fw-bold">A</span>
                        <input type="text" id="newOptA" class="form-control" placeholder="Option A text">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text fw-bold">B</span>
                        <input type="text" id="newOptB" class="form-control" placeholder="Option B text">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text fw-bold">C</span>
                        <input type="text" id="newOptC" class="form-control" placeholder="Option C text">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text fw-bold">D</span>
                        <input type="text" id="newOptD" class="form-control" placeholder="Option D text">
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold small">Correct Answer Key (A/B/C/D)</label>
                <input type="text" id="newAns" class="form-control w-25 text-center fw-bold" maxlength="1">
            </div>

            <div class="d-flex justify-content-between">
                <a href="/Home/Index" class="btn btn-secondary fw-bold">Cancel</a>
                <button id="btnSaveNew" class="btn btn-success fw-bold px-4">Save as JSON & Send to Dashboard</button>
            </div>
        </div>
    </div>
</div>

<script>
    // This script packages the form into JSON and saves it to the browser
    document.getElementById('btnSaveNew').addEventListener('click', function() {
        const title = document.getElementById('newTitle').value.trim();
        const ans = document.getElementById('newAns').value.trim().toUpperCase();

        if (!title || !ans) {
            alert("Please fill out the Question Title and Answer Key!");
            return;
        }

        // 1. Create our standard JSON object
        const newQuestionJSON = {
            id: "Q_Custom_" + Math.floor(Math.random() * 1000), // Generate a fake ID
            questionTitle: title,
            optionA: document.getElementById('newOptA').value.trim(),
            optionB: document.getElementById('newOptB').value.trim(),
            optionC: document.getElementById('newOptC').value.trim(),
            optionD: document.getElementById('newOptD').value.trim(),
            answer: ans
        };

        // 2. Get existing custom questions from memory (or start an empty list)
        let savedQuestions = JSON.parse(localStorage.getItem('myCustomQuestions')) || [];

        // 3. Add the new one to the list
        savedQuestions.push(newQuestionJSON);

        // 4. Save the updated list back to browser memory
        localStorage.setItem('myCustomQuestions', JSON.stringify(savedQuestions));

        // 5. Redirect back to the main dashboard!
        window.location.href = '/Home/Index';
    });
</script>